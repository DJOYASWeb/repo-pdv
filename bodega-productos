function abrirModalCambioPrecio(idProducto, nombreProducto) {
    document.getElementById('cambioPrecioLoading').classList.remove('d-none');
    document.getElementById('cambioPrecioError').classList.add('d-none');
    document.getElementById('cambioPrecioPendiente').classList.add('d-none');
    document.getElementById('formCambioPrecio').classList.add('d-none');
    document.getElementById('btnGuardarCambioPrecio').disabled = true;

    document.getElementById('cp_precio_nuevo_prestashop').value = '';
    document.getElementById('cp_precio_nuevo_tienda').value = '';
    document.getElementById('cp_comentario_registro').value = '';

    var modal = new bootstrap.Modal(document.getElementById('modalCambioPrecio'));
    modal.show();

    fetch('modules/bodega/ajax_producto_cambio_precio.php', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'get_producto_precios', id_producto: idProducto })
    })
    .then(response => response.json())
    .then(data => {
        document.getElementById('cambioPrecioLoading').classList.add('d-none');

        if (!data.success) {
            document.getElementById('cambioPrecioError').textContent = data.message;
            document.getElementById('cambioPrecioError').classList.remove('d-none');
            return;
        }

        if (data.tiene_cambio_pendiente) {
            document.getElementById('cambioPrecioPendiente').classList.remove('d-none');
            return;
        }

        document.getElementById('cp_id_producto').value = data.producto.id_producto;
        document.getElementById('cp_nombre_producto').value = data.producto.nombre_producto || '';
        document.getElementById('cp_codigo_producto').value = data.producto.codigo_producto || '';
        document.getElementById('cp_precio_antiguo_tienda').value = formatearPrecio(data.producto.precio_tienda);
        document.getElementById('cp_precio_antiguo_prestashop').value = formatearPrecio(data.producto.precio_prestashop);

        document.getElementById('formCambioPrecio').classList.remove('d-none');
        document.getElementById('btnGuardarCambioPrecio').disabled = false;
    })
    .catch(error => {
        document.getElementById('cambioPrecioLoading').classList.add('d-none');
        document.getElementById('cambioPrecioError').textContent = 'Error de comunicación con el servidor';
        document.getElementById('cambioPrecioError').classList.remove('d-none');
    });
}

document.getElementById('cp_precio_nuevo_prestashop').addEventListener('input', function() {
    var precioPrestashop = parseInt(this.value) || 0;
    document.getElementById('cp_precio_nuevo_tienda').value = precioPrestashop * 2;
});

document.getElementById('btnGuardarCambioPrecio').addEventListener('click', function() {
    var idProducto = document.getElementById('cp_id_producto').value;
    var precioNuevoPrestashop = parseInt(document.getElementById('cp_precio_nuevo_prestashop').value) || 0;
    var precioNuevoTienda = parseInt(document.getElementById('cp_precio_nuevo_tienda').value) || 0;
    var comentario = document.getElementById('cp_comentario_registro').value.trim();

    if (!precioNuevoPrestashop || !precioNuevoTienda) {
        Swal.fire({ icon: 'warning', title: 'Campos obligatorios', text: 'Debe ingresar el nuevo precio Prestashop.' });
        return;
    }
    if (!comentario) {
        Swal.fire({ icon: 'warning', title: 'Campos obligatorios', text: 'Debe ingresar un comentario explicando el cambio.' });
        return;
    }
    if (precioNuevoTienda != (precioNuevoPrestashop * 2)) {
        Swal.fire({ icon: 'warning', title: 'Validación de precios', text: 'El precio tienda debe ser el doble del precio Prestashop.' });
        return;
    }

    Swal.fire({
        title: '¿Registrar solicitud?',
        html: 'Se enviará la solicitud de cambio de precio para revisión y aprobación.',
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#0d6efd',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Sí, registrar',
        cancelButtonText: 'Cancelar'
    }).then((result) => {
        if (result.isConfirmed) {
            Swal.fire({ title: 'Registrando...', allowOutsideClick: false, showConfirmButton: false, didOpen: () => { Swal.showLoading(); } });

            fetch('modules/bodega/ajax_producto_cambio_precio.php', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    action: 'registrar_cambio_precio',
                    id_producto: idProducto,
                    precio_nuevo_tienda: precioNuevoTienda,
                    precio_nuevo_prestashop: precioNuevoPrestashop,
                    comentario_registro: comentario
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    bootstrap.Modal.getInstance(document.getElementById('modalCambioPrecio')).hide();
                    Swal.fire({ icon: 'success', title: 'Solicitud registrada', text: data.message, confirmButtonText: 'Entendido' });
                } else {
                    Swal.fire({ icon: 'error', title: 'Error', text: data.message });
                }
            })
            .catch(error => {
                Swal.fire({ icon: 'error', title: 'Error', text: 'Error de comunicación con el servidor' });
            });
        }
    });
});

function formatearPrecio(valor) {
    if (!valor) return '0';
    return parseInt(valor).toLocaleString('es-CL');
}

