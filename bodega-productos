    <script>
    // Auto-cerrar mensajes de error y advertencia después de 8 segundos
    document.addEventListener('DOMContentLoaded', function() {
        const alertsToAutoClose = document.querySelectorAll('.alert-danger, .alert-warning');
        
        alertsToAutoClose.forEach(function(alert) {
            // Agregar una barra de progreso visual
            const progressBar = document.createElement('div');
            progressBar.style.cssText = 'position: absolute; bottom: 0; left: 0; height: 3px; background-color: rgba(255, 255, 255, 0.7); width: 100%; animation: shrink 8s linear;';
            alert.style.position = 'relative';
            alert.style.overflow = 'hidden';
            alert.appendChild(progressBar);
            
            // Auto-cerrar después de 8 segundos
            setTimeout(function() {
                // Usar Bootstrap para cerrar la alerta con animación
                const bsAlert = bootstrap.Alert.getOrCreateInstance(alert);
                bsAlert.close();
            }, 8000);
        });
    });
    
    // Agregar animación CSS para la barra de progreso
    if (!document.getElementById('alert-auto-close-styles')) {
        const style = document.createElement('style');
        style.id = 'alert-auto-close-styles';
        style.textContent = `
            @keyframes shrink {
                from { width: 100%; }
                to { width: 0%; }
            }
        `;
        document.head.appendChild(style);
    }
    </script>
